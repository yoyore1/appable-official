# ==========================================================================
# APPABLE PLATFORM — environment variables
# Copy to .env.local and fill in. EVERY value is optional for local dev:
# if a service's keys are missing, the app runs in MOCK MODE for that service
# (mock auth, mock payments, mock AI) so you can develop with zero accounts.
# ==========================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Service key the Builder/build-engine uses to call platform APIs (auth, cache, usage).
APPABLE_SERVICE_KEY=dev-service-key

# --- Supabase (auth, Postgres, storage; enable the pgvector extension) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (products + webhook signing secret) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Chat model (interview acks + ASO copy). Step 3.5 Flash. ---
CHAT_MODEL_BASE_URL=
CHAT_MODEL_KEY=
CHAT_MODEL_NAME=stepfun-ai/Step-3.5-Flash

# --- Plan model (final interview → master build prompt). Kimi K2.6. ---
BUILD_MODEL_BASE_URL=
BUILD_MODEL_KEY=
BUILD_MODEL_NAME=moonshotai/Kimi-K2.6

# --- Image model (launch-pack screenshots + icon). Will be GPT Image 2. ---
IMAGE_MODEL_BASE_URL=
IMAGE_MODEL_KEY=
IMAGE_MODEL_NAME=gpt-image-2

# --- Video model (launch-pack video ads). Will be Seedance. Stub for now. ---
VIDEO_API_BASE_URL=
VIDEO_API_KEY=

# ==========================================================================
# CONFIG CONSTANTS (tune freely; these are also defined in src/lib/config.ts)
# ==========================================================================
# Build power granted per pack purchase.
BUILD_POWER_PACK_SMALL=1000
BUILD_POWER_PACK_MEDIUM=3000
BUILD_POWER_PACK_LARGE=7000
# Review balance granted by the $1.99 review top-up.
REVIEW_TOPUP_AMOUNT=50
# Build power granted by the $1 starter deposit (becomes non-refundable build credit).
DEPOSIT_BUILD_POWER=100
