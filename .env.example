# ==========================================================================
# APPABLE PLATFORM — environment variables
# Copy to .env.local and fill in. EVERY value is optional for local dev:
# if a service's keys are missing, the app runs in MOCK MODE for that service
# (mock auth, mock payments, mock AI) so you can develop with zero accounts.
# ==========================================================================

# --- App ---
# Local dev: localhost is fine on desktop. Phone QR uses your Wi‑Fi IP automatically.
# Or set this to http://YOUR_LAN_IP:3000 (e.g. http://192.168.1.42:3000) and open the site at that URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APPABLE_SERVICE_KEY=dev-service-key

# Encrypts Supabase connector keys at rest (32+ char random string in production).
CONNECTOR_ENCRYPTION_KEY=
APPABLE_BUILDER_PROTOCOL=appable

# --- GitHub org (one private repo per app) ---
GITHUB_ORG_TOKEN=
GITHUB_ORG=appable-apps

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- OpenRouter (premium escalation only — complex reasoning / vision / quality images) ---
# Most traffic stays on DeepInfra; OpenRouter is used for frontier tasks when set.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REASONING_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_IMAGE_MODEL=openai/gpt-4o
# OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini

# --- DeepInfra (one key powers chat, build, vision, images, STT, TTS, embed, rerank) ---
# Setting DEEPINFRA_API_KEY alone is enough for brainstorm + interview chat (Qwen 3.6).
DEEPINFRA_API_KEY=
DEEPINFRA_OPENAI_BASE=https://api.deepinfra.com/v1/openai
DEEPINFRA_INFERENCE_BASE=https://api.deepinfra.com/v1/inference

# Chat / interview / brainstorm coach — Qwen 3.6 (OpenAI /chat/completions)
# Optional overrides; defaults to DEEPINFRA_API_KEY + DEEPINFRA_OPENAI_BASE above.
CHAT_MODEL_BASE_URL=https://api.deepinfra.com/v1/openai
CHAT_MODEL_KEY=
CHAT_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# Expo Go QR — run `npm run expo:dev` in a second terminal; URL auto-saved to .data/expo-dev-url.json
# Or paste the exp:// URL from Metro here:
# NEXT_PUBLIC_EXPO_DEV_SERVER_URL=exp://xxxx.exp.direct

# Interview (acks, engineer pool, pills) uses CHAT_MODEL above — Qwen only

# App code + master prompt — Kimi K2.6
BUILD_MODEL_BASE_URL=https://api.deepinfra.com/v1/openai
BUILD_MODEL_KEY=
BUILD_MODEL_NAME=moonshotai/Kimi-K2.6

# Vision — Qwen3-VL (OCR: pass image URL)
VISION_MODEL_NAME=Qwen/Qwen3-VL-30B-A3B-Instruct

# Image generation — FLUX-2-klein-4b
IMAGE_MODEL_NAME=black-forest-labs/FLUX-2-klein-4b

# Speech-to-text — Whisper turbo
STT_MODEL_NAME=openai/whisper-large-v3-turbo

# Text-to-speech — Qwen3-TTS (cap hard on free tier)
TTS_MODEL_NAME=Qwen/Qwen3-TTS

# Embeddings + reranker
EMBED_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
RERANK_MODEL_NAME=Qwen/Qwen3-Reranker-0.6B

# --- fal.ai — launch-pack ad video ONLY (Seedance 2.0) ---
FAL_KEY=
SEEDANCE_MODEL=bytedance/seedance-2.0/image-to-video

# ==========================================================================
# CONFIG CONSTANTS
# ==========================================================================
BUILD_POWER_PACK_SMALL=1000
BUILD_POWER_PACK_MEDIUM=3000
BUILD_POWER_PACK_LARGE=7000
REVIEW_TOPUP_AMOUNT=50
DEPOSIT_BUILD_POWER=100
