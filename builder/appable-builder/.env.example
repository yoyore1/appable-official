# =========================================================================
# APPABLE BUILDER ENGINE — environment
# All optional for local dev. With no keys the engine runs in MOCK MODE:
# a deterministic agent generates a real SwiftUI project, and platform calls
# fall back to a baked-in sample master prompt.
# =========================================================================

# --- Coding agent: Kimi K2.6 via DeepInfra (OpenAI-compatible) ---
BUILD_MODEL_BASE_URL=
BUILD_MODEL_KEY=
BUILD_MODEL_NAME=moonshotai/Kimi-K2.6

# --- Secondary/cheap model (summaries, small fixes) — Step 3.5 Flash ---
CHAT_MODEL_BASE_URL=
CHAT_MODEL_KEY=
CHAT_MODEL_NAME=step-3.5-flash

# --- Appable platform (Part 1). Point at your running platform to use real
#     master prompts, usage reporting, and the build cache. ---
APPABLE_API_URL=http://localhost:3000
APPABLE_API_KEY=dev-service-key
# Skip login validate against localhost — project ID + service key only (dev testing)
APPABLE_DEV_BYPASS=true

# --- Budgets & caps (configurable) ---
BASE_BUILD_BUDGET=40000      # base (free) build token budget — UI only
FULL_BUILD_BUDGET=200000     # full (paid) build token budget — real backend
ERROR_FIX_MAX_ROUNDS=6       # error-fixing iteration cap
BUILD_REVIEW_SPLIT=0.8       # 80% build / 20% review usage split

# --- Output ---
APPABLE_OUTPUT_DIR=./builds  # where generated Xcode projects are written
